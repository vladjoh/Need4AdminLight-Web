<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>need4admin-light-a1b2c3d4-e5f6-7890-abcd-ef1234567890</UserSecretsId>
    <!-- Never treat local deploy trees as project content (avoids duplicate static web assets) -->
    <DefaultItemExcludes>$(DefaultItemExcludes);publish\**;publishnew\**;publish_release\**</DefaultItemExcludes>
    <!-- Build gzip duplicates routes and breaks GenerateStaticWebAssetsDevelopmentManifest (SDK) -->
    <DisableBuildCompression>true</DisableBuildCompression>
  </PropertyGroup>

  <!-- Local deploy folders must not be copied into publish output -->
  <ItemGroup>
    <Content Remove="publish\**" />
    <Content Remove="publish_release\**" />
    <Content Remove="publishnew\**" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="ENTRA-APP-PERMISSIONS.md" CopyToPublishDirectory="PreserveNewest" />
    <Content Include="PERMISSIONS.md" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
