@inject Microsoft.Extensions.Options.IOptions<Need4AdminOptions> Need4AdminOptionsAccessor
@{
    var n4a = Need4AdminOptionsAccessor.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @n4a.ProductName</title>
    <script>window.n4aLightweight = true;</script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site-retro.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Need4AdminLight.Web.styles.css" asp-append-version="true" />
</head>
<body class="app-body n4a-lightweight n4a-retro-ui">
    <div class="app-background" aria-hidden="true"></div>
    <div id="scan-overlay" class="scan-overlay" aria-hidden="true" role="status">
        <div class="scan-card">
            <div class="scan-spinner"></div>
            <p class="scan-title" id="scan-overlay-title">Generating report</p>
            <p class="scan-text" id="scan-overlay-text">Need4Admin Light — preparing report.</p>
            <p class="scan-text scan-text-sub" id="scan-overlay-sub">Please wait until report window opens.</p>
        </div>
    </div>
    <header class="app-header">
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark app-navbar mb-0">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-page="/Index">
                    <span class="app-brand-text">@n4a.ProductName</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link app-nav-link" asp-area="" asp-page="/Overview">Overview</a>
                            </li>
                        }
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="nav-link app-nav-link" asp-area="" asp-page="/PrivilegedUsers" data-scan="true" data-scan-title="Privileged users report" data-scan-text="Need4Admin Light — scanning privileged users.">Privileged users</a>
                            }
                            else
                            {
                                <a class="nav-link app-nav-link" asp-area="" asp-page="/PrivilegedUsers">Privileged users</a>
                            }
                        </li>
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="nav-link app-nav-link" asp-area="" asp-page="/Applications" data-scan="true" data-scan-title="Applications report" data-scan-text="Need4Admin Light — scanning applications.">Applications</a>
                            }
                            else
                            {
                                <a class="nav-link app-nav-link" asp-area="" asp-page="/Applications">Applications</a>
                            }
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            var displayName = User.FindFirst("display_name")?.Value;
                            <li class="nav-item d-flex align-items-center py-1 py-sm-0">
                                <div class="app-nav-user-wrap text-end me-2">
                                    <div class="app-nav-user-label">Signed in</div>
                                    <div class="app-nav-user-name">@(string.IsNullOrWhiteSpace(displayName) ? User.Identity!.Name : displayName)</div>
                                    <div class="app-nav-user-upn">@User.Identity!.Name</div>
                                </div>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link app-nav-link n4a-signout" href="/signout" title="Sign out">Sign out</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link app-nav-link app-nav-cta" href="/signin">Sign in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container app-container">
        <main role="main" class="app-main pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer app-footer--author footer text-muted no-print">
        <div class="container app-footer-inner py-4">
            <div class="app-footer-center">
                <div class="app-footer-meta-block">
                    <p class="app-footer-meta-line mb-0">Built by Vlad Johansen for the community</p>
                    <p class="app-footer-meta-line mb-0">Need4Admin © 2026 · All rights reserved</p>
                </div>
                <div class="app-footer-social">
                    <a href="https://www.linkedin.com/in/vladjoh" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile" class="app-footer-social-link">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <a href="https://github.com/vladjoh/Need4AdminLight-Web" target="_blank" rel="noopener noreferrer" aria-label="Need4Admin Light on GitHub" class="app-footer-social-link">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
